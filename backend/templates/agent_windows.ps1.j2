# AuditForge Connect Agent - Windows
# OUTBOUND WebSocket only. NEVER listens on any port.
# Self-terminates after {{ max_lifetime_seconds }} seconds.
# Generated by AuditForge — do not modify.

$token = '{{ token }}'
$serverHost = '{{ server_host }}'
$serverPort = '{{ server_port }}'
$maxLifetime = {{ max_lifetime_seconds }}
$wsUri = "ws://${serverHost}:${serverPort}/ws/agent/${token}"
$startTime = Get-Date

Write-Host "[AuditForge] Connecting to ${serverHost}:${serverPort} ..."

# ── Collect system info ──────────────────────────────────────────
$osInfo = Get-CimInstance Win32_OperatingSystem -ErrorAction SilentlyContinue
$ipAddrs = @(
    (Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
     Where-Object { $_.IPAddress -ne '127.0.0.1' -and $_.IPAddress -ne '0.0.0.0' }).IPAddress
)
$openPorts = @(
    (Get-NetTCPConnection -State Listen -ErrorAction SilentlyContinue).LocalPort |
    Sort-Object -Unique | Select-Object -First 50
)

$sysInfoPayload = @{
    hostname     = $env:COMPUTERNAME
    os           = 'windows'
    os_version   = "$($osInfo.Caption) $($osInfo.Version)"
    ip_addresses = $ipAddrs
    open_ports   = $openPorts
}

# ── WebSocket setup ──────────────────────────────────────────────
$ws = $null
$cts = New-Object System.Threading.CancellationTokenSource
$enc = [System.Text.Encoding]::UTF8

function Send-WsJson($obj) {
    $json = $obj | ConvertTo-Json -Depth 10 -Compress
    $bytes = $enc.GetBytes($json)
    $seg = [System.ArraySegment[byte]]::new($bytes)
    $ws.SendAsync($seg, [System.Net.WebSockets.WebSocketMessageType]::Text, $true, $cts.Token).Wait()
}

function Recv-WsJson {
    $buf = [byte[]]::new(65536)
    $seg = [System.ArraySegment[byte]]::new($buf)
    $result = $ws.ReceiveAsync($seg, $cts.Token).GetAwaiter().GetResult()
    if ($result.MessageType -eq [System.Net.WebSockets.WebSocketMessageType]::Close) { return $null }
    $enc.GetString($buf, 0, $result.Count) | ConvertFrom-Json
}

# ── Connect (with 1 retry) ──────────────────────────────────────
$connected = $false
for ($attempt = 1; $attempt -le 2; $attempt++) {
    try {
        $ws = New-Object System.Net.WebSockets.ClientWebSocket
        $ws.ConnectAsync([Uri]$wsUri, $cts.Token).Wait(15000)
        if ($ws.State -ne [System.Net.WebSockets.WebSocketState]::Open) {
            throw [System.Exception]::new("WebSocket state is $($ws.State) after connect")
        }
        $connected = $true
        Write-Host "[AuditForge] Connected to $serverHost"
        break
    } catch {
        $errMsg = $_.Exception.Message
        if ($_.Exception.InnerException) { $errMsg = $_.Exception.InnerException.Message }
        Write-Host "[AuditForge] Connection attempt $attempt failed: $errMsg"
        if ($ws) { try { $ws.Dispose() } catch { } }
        $ws = $null
        if ($attempt -lt 2) {
            Write-Host "[AuditForge] Retrying in 5 seconds..."
            Start-Sleep -Seconds 5
        }
    }
}

if (-not $connected) {
    Write-Host "[AuditForge] All connection attempts failed. Exiting."
    $cts.Dispose()
    Write-Host "[AuditForge] Agent terminated. No processes or ports remain."
    exit 1
}

# ── Main loop ────────────────────────────────────────────────────
try {
    Send-WsJson @{ type = 'system_info'; payload = $sysInfoPayload }

    while ($ws.State -eq [System.Net.WebSockets.WebSocketState]::Open) {
        # Check max lifetime
        if (((Get-Date) - $startTime).TotalSeconds -ge $maxLifetime) {
            Write-Host "[AuditForge] Max lifetime reached. Exiting."
            break
        }

        $msg = Recv-WsJson
        if ($null -eq $msg) { break }

        switch ($msg.type) {
            'ping' {
                Send-WsJson @{ type = 'pong' }
            }
            'command' {
                $cmdId = $msg.payload.id
                $cmdText = $msg.payload.command
                $sw = [System.Diagnostics.Stopwatch]::StartNew()
                try {
                    $output = Invoke-Expression $cmdText 2>&1 | Out-String
                    $exitCode = $LASTEXITCODE
                    if ($null -eq $exitCode) { $exitCode = 0 }
                } catch {
                    $output = $_.Exception.Message
                    $exitCode = 1
                }
                $sw.Stop()

                Send-WsJson @{
                    type    = 'command_result'
                    payload = @{
                        id                = $cmdId
                        stdout            = ($output -replace '\r\n', "`n").Trim()
                        stderr            = ''
                        exit_code         = $exitCode
                        execution_time_ms = [int]$sw.ElapsedMilliseconds
                    }
                }
            }
            'terminate' {
                Write-Host "[AuditForge] Terminate received. Exiting."
                break
            }
        }
    }
} catch {
    $errMsg = $_.Exception.Message
    if ($_.Exception.InnerException) { $errMsg = $_.Exception.InnerException.Message }
    Write-Host "[AuditForge] Error: $errMsg"
} finally {
    try {
        if ($ws -and $ws.State -eq [System.Net.WebSockets.WebSocketState]::Open) {
            $ws.CloseAsync(
                [System.Net.WebSockets.WebSocketCloseStatus]::NormalClosure,
                'Agent exiting', $cts.Token
            ).Wait(5000)
        }
    } catch { }
    if ($ws) { try { $ws.Dispose() } catch { } }
    try { $cts.Dispose() } catch { }
    Write-Host "[AuditForge] Agent terminated. No processes or ports remain."
}
