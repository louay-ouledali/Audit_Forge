<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title or "Audit Report" }}</title>
<style>
  @page { size: A4; margin: 20mm; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 11px; color: #222; line-height: 1.5; }
  .cover { text-align: center; padding: 80px 40px 60px; page-break-after: always; }
  .cover h1 { font-size: 28px; color: #1a237e; margin-bottom: 10px; }
  .cover .subtitle { font-size: 14px; color: #555; margin-bottom: 30px; }
  .cover .meta-line { font-size: 12px; color: #444; margin: 4px 0; }

  h2 { font-size: 16px; color: #283593; margin: 20px 0 8px; border-bottom: 2px solid #c5cae9; padding-bottom: 4px; }
  h3 { font-size: 13px; color: #37474f; margin: 12px 0 6px; }

  .section { margin-bottom: 20px; }

  /* Statistics cards */
  .stats { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
  .stat-card { background: #e8eaf6; padding: 10px 16px; border-radius: 6px; text-align: center; min-width: 110px; }
  .stat-card .val { font-size: 22px; font-weight: 700; color: #1a237e; }
  .stat-card .lbl { font-size: 9px; color: #555; text-transform: uppercase; }

  table { width: 100%; border-collapse: collapse; margin-top: 6px; font-size: 10px; }
  th, td { padding: 5px 8px; border: 1px solid #ccc; text-align: left; }
  th { background: #e8eaf6; font-weight: 600; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 9px; font-weight: 700; color: #fff; }
  .sev-critical { background: #d32f2f; }
  .sev-high { background: #e65100; }
  .sev-medium { background: #f9a825; color: #333; }
  .sev-low { background: #1565c0; }
  .st-pass { background: #2e7d32; }
  .st-fail { background: #c62828; }
  .st-error { background: #6a1b9a; }

  .finding-card { border: 1px solid #ddd; border-radius: 6px; padding: 10px; margin-bottom: 10px; page-break-inside: avoid; }
  .finding-card .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .finding-card .header .rule-id { font-weight: 700; }
  .finding-card p { margin: 3px 0; }
  .finding-card code { background: #f5f5f5; padding: 1px 4px; border-radius: 3px; font-size: 10px; }
  .finding-card .field-label { font-weight: 600; color: #444; }

  .passed-summary { margin-top: 12px; }
  .passed-summary li { margin-left: 18px; font-size: 10px; }

  .ai-summary { background: #f0f4ff; border-left: 4px solid #1a237e; padding: 10px 14px; margin-bottom: 16px; white-space: pre-wrap; }
</style>
</head>
<body>

<!-- Cover -->
<div class="cover">
  <h1>{{ title or "Configuration Audit Report" }}</h1>
  <div class="subtitle">{{ mission_name }}</div>
  <div class="meta-line"><strong>Client:</strong> {{ client_name }}</div>
  <div class="meta-line"><strong>Date Range:</strong> {{ date_range }}</div>
  <div class="meta-line"><strong>Generated:</strong> {{ generated_at }}</div>
</div>

<!-- AI Summary -->
{% if ai_summary %}
<div class="section">
  <h2>AI Executive Summary</h2>
  <div class="ai-summary">{{ ai_summary }}</div>
</div>
{% endif %}

<!-- Executive Summary -->
<div class="section">
  <h2>Executive Summary</h2>
  <div class="stats">
    <div class="stat-card"><div class="val">{{ summary.overall_compliance }}%</div><div class="lbl">Compliance</div></div>
    <div class="stat-card"><div class="val">{{ summary.total_rules }}</div><div class="lbl">Total Rules</div></div>
    <div class="stat-card"><div class="val">{{ summary.passed }}</div><div class="lbl">Passed</div></div>
    <div class="stat-card"><div class="val">{{ summary.failed }}</div><div class="lbl">Failed</div></div>
    <div class="stat-card"><div class="val">{{ summary.errors }}</div><div class="lbl">Errors</div></div>
  </div>

  <h3>Findings by Severity</h3>
  <table>
    <thead><tr><th>Severity</th><th>Total</th><th>Passed</th><th>Failed</th><th>Compliance</th></tr></thead>
    <tbody>
      {% for sev in ["critical", "high", "medium", "low"] %}
      {% set info = summary.by_severity.get(sev, {"total": 0, "passed": 0, "failed": 0}) %}
      <tr>
        <td><span class="badge sev-{{ sev }}">{{ sev | upper }}</span></td>
        <td>{{ info.total }}</td>
        <td>{{ info.passed }}</td>
        <td>{{ info.failed }}</td>
        <td>{{ "%.1f" | format(info.passed / info.total * 100) if info.total > 0 else "0.0" }}%</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {% set top5 = namespace(items=[]) %}
  {% for f in findings if f.status == "FAIL" and f.severity in ["critical", "high"] %}
    {% if top5.items | length < 5 %}
      {% set top5.items = top5.items + [f] %}
    {% endif %}
  {% endfor %}
  {% if top5.items %}
  <h3>Top Critical / High Findings</h3>
  <table>
    <thead><tr><th>Section</th><th>Rule</th><th>Severity</th><th>Target</th></tr></thead>
    <tbody>
      {% for f in top5.items %}
      <tr>
        <td>{{ f.section_number }}</td>
        <td>{{ f.rule_title }}</td>
        <td><span class="badge sev-{{ f.severity }}">{{ f.severity | upper }}</span></td>
        <td>{{ f.target_hostname }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</div>

<!-- Scope -->
<div class="section">
  <h2>Audit Scope</h2>
  <table>
    <thead><tr><th>Target</th><th>IP Address</th><th>Type</th><th>OS</th><th>Benchmark</th><th>Compliance</th><th>Scan Date</th></tr></thead>
    <tbody>
      {% for t in targets %}
        {% for s in t.scans %}
        <tr>
          <td>{{ t.hostname }}</td>
          <td>{{ t.ip_address }}</td>
          <td>{{ t.target_type }}</td>
          <td>{{ t.os_details }}</td>
          <td>{{ s.benchmark_name }}</td>
          <td>{{ s.compliance_percentage }}%</td>
          <td>{{ s.completed_at }}</td>
        </tr>
        {% endfor %}
      {% endfor %}
    </tbody>
  </table>
</div>

<!-- Detailed Findings (FAIL only) -->
<div class="section">
  <h2>Detailed Findings — Failed Rules</h2>
  {% for f in findings if f.status == "FAIL" %}
  <div class="finding-card">
    <div class="header">
      <span class="rule-id">{{ f.section_number }} — {{ f.rule_title }}</span>
      <span><span class="badge sev-{{ f.severity }}">{{ f.severity | upper }}</span> <span class="badge st-fail">FAIL</span></span>
    </div>
    {% if f.description %}<p><span class="field-label">Description:</span> {{ f.description }}</p>{% endif %}
    <p><span class="field-label">Expected:</span> <code>{{ f.expected_output }}</code></p>
    <p><span class="field-label">Actual:</span> <code>{{ f.actual_output }}</code></p>
    {% if f.remediation %}<p><span class="field-label">Remediation:</span> {{ f.remediation }}</p>{% endif %}
    {% if f.auditor_notes %}<p><span class="field-label">Auditor Notes:</span> {{ f.auditor_notes }}</p>{% endif %}
    {% if f.auditor_override %}<p><span class="field-label">Override:</span> {{ f.auditor_override }}</p>{% endif %}
  </div>
  {% endfor %}
</div>

<!-- Passed Rules Summary -->
{% if include_passed %}
<div class="section">
  <h2>Passed Rules Summary</h2>
  <table>
    <thead><tr><th>Section</th><th>Rule</th><th>Severity</th><th>Target</th></tr></thead>
    <tbody>
      {% set has_passed = namespace(val=false) %}
      {% for f in findings if f.status == "PASS" %}
      {% set has_passed.val = true %}
      <tr>
        <td>{{ f.section_number }}</td>
        <td>{{ f.rule_title }}</td>
        <td><span class="badge sev-{{ f.severity }}">{{ f.severity | upper }}</span></td>
        <td>{{ f.target_hostname }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if not has_passed.val %}
  <p>No passed rules recorded.</p>
  {% endif %}
</div>
{% endif %}

</body>
</html>
