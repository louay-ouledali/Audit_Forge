#!/usr/bin/env bash
# AuditForge Connect Agent - Linux
# OUTBOUND WebSocket only. NEVER listens on any port.
# Self-terminates after {{ max_lifetime_seconds }} seconds.
# Generated by AuditForge — do not modify.

set -euo pipefail

TOKEN="{{ token }}"
SERVER_HOST="{{ server_host }}"
SERVER_PORT="{{ server_port }}"
MAX_LIFETIME={{ max_lifetime_seconds }}
WS_URI="ws://${SERVER_HOST}:${SERVER_PORT}/ws/agent/${TOKEN}"
START_TIME=$(date +%s)

echo "[AuditForge] Connecting to ${SERVER_HOST}:${SERVER_PORT}..."

# Collect system info
HOSTNAME_VAL=$(hostname 2>/dev/null || echo "unknown")
OS_VERSION=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2 || uname -sr)
IP_ADDRS=$(hostname -I 2>/dev/null | tr ' ' ',' || ip -4 addr show | grep inet | awk '{print $2}' | cut -d/ -f1 | tr '\n' ',')
OPEN_PORTS=$(ss -tlnp 2>/dev/null | awk 'NR>1 {split($4,a,":"); print a[length(a)]}' | sort -un | head -50 | tr '\n' ',' || echo "")

# Use Python3 for WebSocket (near-universal on Linux)
python3 << 'AGENT_SCRIPT'
import json, subprocess, sys, time, os, signal

TOKEN = os.environ.get("TOKEN", "{{ token }}")
WS_URI = os.environ.get("WS_URI", "ws://{{ server_host }}:{{ server_port }}/ws/agent/{{ token }}")
MAX_LIFETIME = int(os.environ.get("MAX_LIFETIME", "{{ max_lifetime_seconds }}"))
START = time.time()

# Install websocket-client if needed
try:
    import websocket
except ImportError:
    subprocess.check_call(
        [sys.executable, "-m", "pip", "install", "--quiet", "--break-system-packages",
         "websocket-client"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    import websocket

def send_msg(ws, msg_type, payload):
    ws.send(json.dumps({"type": msg_type, "payload": payload}))

def main():
    ws = websocket.create_connection(WS_URI, timeout=30)
    print("[AuditForge] Connected.")

    # Send system info
    send_msg(ws, "system_info", {
        "hostname": """{{ "{{HOSTNAME_VAL}}" }}""".replace("{{HOSTNAME_VAL}}", os.popen("hostname 2>/dev/null").read().strip() or "unknown"),
        "os": "linux",
        "os_version": os.popen("cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'\"' -f2").read().strip() or "Linux",
        "ip_addresses": [ip for ip in os.popen("hostname -I 2>/dev/null").read().strip().split() if ip],
        "open_ports": [int(p) for p in os.popen("ss -tlnp 2>/dev/null | awk 'NR>1 {split($4,a,\":\"); print a[length(a)]}'").read().strip().split("\n") if p.isdigit()][:50],
    })

    while True:
        # Check lifetime
        if time.time() - START >= MAX_LIFETIME:
            print("[AuditForge] Max lifetime reached. Exiting.")
            break

        try:
            raw = ws.recv()
        except websocket.WebSocketTimeoutError:
            continue
        except Exception:
            break

        msg = json.loads(raw)
        msg_type = msg.get("type", "")

        if msg_type == "ping":
            send_msg(ws, "pong", {})

        elif msg_type == "command":
            cmd_id = msg["payload"]["id"]
            cmd_text = msg["payload"]["command"]
            timeout = msg["payload"].get("timeout", 30)
            start = time.time()
            try:
                proc = subprocess.run(
                    ["bash", "-c", cmd_text],
                    capture_output=True, text=True, timeout=timeout,
                )
                stdout = proc.stdout.strip()
                stderr = proc.stderr.strip()
                exit_code = proc.returncode
            except subprocess.TimeoutExpired:
                stdout, stderr, exit_code = "", "Command timed out", -1
            except Exception as e:
                stdout, stderr, exit_code = "", str(e), -1
            elapsed = int((time.time() - start) * 1000)
            send_msg(ws, "command_result", {
                "id": cmd_id,
                "stdout": stdout[:4000],
                "stderr": stderr[:1000],
                "exit_code": exit_code,
                "execution_time_ms": elapsed,
            })

        elif msg_type == "terminate":
            print("[AuditForge] Terminate received. Exiting.")
            break

    ws.close()
    print("[AuditForge] Agent terminated. No processes or ports remain.")

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"[AuditForge] Connection failed: {e}")
        print("[AuditForge] Retrying in 30 seconds...")
        time.sleep(30)
        try:
            main()
        except Exception:
            print("[AuditForge] Retry failed. Exiting.")
AGENT_SCRIPT
